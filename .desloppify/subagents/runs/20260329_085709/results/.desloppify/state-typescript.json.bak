      "id": "review::.::holistic::naming_quality::api_call_fn_any_return",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "ApiCallFn type alias uses 'any' in return type \u2014 data field is untyped",
      "detail": {
        "holistic": true,
        "dimension": "naming_quality",
        "related_files": [
          "src/actions/action-executor.ts"
        ],
        "evidence": [
          "Line 29: 'export type ApiCallFn = (path: string, token: string, opts?: { method?: string; body?: string }) => Promise<{ ok: boolean; status?: number; data?: any }>;' \u2014 the 'data?: any' leaks type-unsafety through the API call abstraction name. While this file is documented as orphaned, the pattern could be copied."
