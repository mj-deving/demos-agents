    "review::.::holistic::error_consistency::auth_null_no_context": {
      "id": "review::.::holistic::error_consistency::auth_null_no_context",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "auth.ts returns null for all failure modes \u2014 no error context preserved",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "src/lib/auth/auth.ts"
        ],
        "evidence": [
          "loadAuthCache() returns null for: file not found, JSON parse failure, expired token, wrong address, missing fields. ensureAuth returns null when API is unreachable. Callers cannot distinguish between 'no cached token', 'expired token', and 'auth challenge failed' \u2014 all get the same null."
        ],
        "suggestion": "Return a discriminated union type: { status: 'ok', token: string } | { status: 'expired' } | { status: 'missing' } | { status: 'error', message: string }. This preserves context without changing the null-check pattern at call sites (callers check .status instead of nullness).",
        "reasoning": "",
        "summary_hash": "51f2a301"
      },
      "status": "open",
      "note": null,
