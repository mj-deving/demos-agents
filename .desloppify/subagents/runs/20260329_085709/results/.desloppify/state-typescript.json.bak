    "review::.::holistic::contract_coherence::sdk_apicall_data_type_lie": {
      "id": "review::.::holistic::contract_coherence::sdk_apicall_data_type_lie",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "apiCall<TData> in sdk.ts returns error message string as TData on network failure",
      "detail": {
        "holistic": true,
        "dimension": "contract_coherence",
        "related_files": [
          "src/lib/network/sdk.ts"
        ],
        "evidence": [
          "Line 298: on catch, returns { ok: false, status: 0, data: message as TData }. The data field is typed as TData (generic) but receives a plain string error message. Callers checking ok=false before accessing data are safe, but the type annotation lies about what data contains on error paths."
        ],
        "suggestion": "Change ApiCallResult to use a discriminated union: { ok: true; status: number; data: TData } | { ok: false; status: number; data: string; errorType?: string }. This makes the type system enforce error checking before accessing TData-shaped data.",
        "reasoning": "",
        "summary_hash": "6d4db76e"
      },
      "status": "open",
