    "review::.::holistic::error_consistency::plugin_silent_swallowing": {
      "id": "review::.::holistic::error_consistency::plugin_silent_swallowing",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Plugins have 18 try-catch blocks but only 1 throw \u2014 errors are systematically caught and swallowed",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "src/plugins/tips-plugin.ts",
          "src/plugins/sources-plugin.ts",
          "src/plugins/signals-plugin.ts"
        ],
        "evidence": [
          "Plugin directory error strategy: try_catch: 18, throws: 1. Most plugin hooks catch errors, log them via ctx.logger, and return without propagation. This is intentional at the boundary but means plugin failures produce no signal to the caller beyond log output."
        ],
        "suggestion": "Add a hookErrors accumulator pattern (already partially implemented in BeforeSenseContext.hookErrors) to all plugin hook contexts, so the session runner can inspect which hooks failed and decide whether to abort or continue. This preserves the graceful degradation while making failures visible to the orchestrator.",
        "reasoning": "",
        "summary_hash": "9826d99d"
      },
      "status": "open",
      "note": null,
