    "review::.::holistic::initialization_coupling::sdk_mutable_exported_lets": {
      "id": "review::.::holistic::initialization_coupling::sdk_mutable_exported_lets",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "sdk.ts exports mutable lets (RPC_URL, SUPERCOLONY_API) that are silently mutated by loadMnemonic() side effects",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "src/lib/network/sdk.ts"
        ],
        "evidence": [
          "Line 25: 'export let RPC_URL = \"https://demosnode.discus.sh/\"' \u2014 default value overwritten by applyConfigOverrides()",
          "Line 26: 'export let SUPERCOLONY_API = \"https://www.supercolony.ai\"' \u2014 same pattern",
          "applyConfigOverrides() is called inside loadMnemonic() \u2014 any importer reading RPC_URL before loadMnemonic() gets the default, after gets the override",
          "12 files import from sdk.ts \u2014 wide blast radius for stale-snapshot bugs",
          "connectWallet() reads resolvedAlgorithm which is set by the same side-effecting path"
        ],
        "suggestion": "Replace mutable module-level state with a config object returned by loadMnemonic() or a lazy getter. For example: export function getRpcUrl(): string { return _rpcUrl; } \u2014 or better, make loadMnemonic() return a config object { mnemonic, rpcUrl, apiUrl, algorithm, dualSign } and thread it to consumers explicitly.",
        "reasoning": "",
        "summary_hash": "fe810ec6"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-28T17:34:30+00:00",
      "last_seen": "2026-03-28T17:34:30+00:00",
