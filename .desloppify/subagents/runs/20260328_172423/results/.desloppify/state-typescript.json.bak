    "review::.::holistic::cross_module_architecture::sdk_module_mutable_state": {
      "id": "review::.::holistic::cross_module_architecture::sdk_module_mutable_state",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "src/lib/network/sdk.ts exports mutable module-level state (RPC_URL, SUPERCOLONY_API) creating hidden coupling",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "src/lib/network/sdk.ts"
        ],
        "evidence": [
          "Lines 25-27: export let RPC_URL, export let SUPERCOLONY_API, let logAgentName \u2014 module-level mutable values that any importer can read but only applyConfigOverrides mutates",
          "12 importers of this file share this implicit mutable state \u2014 a mutation in one session affects all consumers"
        ],
        "suggestion": "Since the toolkit already has session-scoped state via SdkBridge, this legacy module-level mutable state is a relic of the pre-toolkit architecture. Either (1) make these constants truly const and pass overrides through function parameters, or (2) encapsulate in a config object returned by a factory function. The toolkit's sdk-bridge.ts already demonstrates the session-scoped pattern correctly.",
        "reasoning": "",
        "summary_hash": "9d3bf504"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-28T17:34:30+00:00",
