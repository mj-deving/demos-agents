    "review::.::holistic::logic_clarity::publish_txhash_extraction_chain": {
      "id": "review::.::holistic::logic_clarity::publish_txhash_extraction_chain",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "publishPost txHash extraction uses 7-deep as-any fallback chain that duplicates sdk-bridge's typed extractTxHash",
      "detail": {
        "holistic": true,
        "dimension": "logic_clarity",
        "related_files": [
          "src/actions/publish-pipeline.ts"
        ],
        "evidence": [
          "Lines 333-341: `const confirmHash = (validity as any)?.response?.data?.transaction?.hash; const results = (result as any).response?.results; const txHash = confirmHash || (results ? results[...] : (result as any)?.response?.data?.transaction?.hash || ...)` \u2014 this exact pattern was already extracted to the typed extractTxHash helper in sdk-bridge.ts"
        ],
        "suggestion": "Import and use extractTxHash from sdk-bridge.ts (or better, extract to a shared utility since both files need it). This removes the untyped fallback chain and the risk of the two copies diverging.",
        "reasoning": "",
        "summary_hash": "531b04eb"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-28T17:34:30+00:00",
      "last_seen": "2026-03-28T17:34:30+00:00",
      "resolved_at": null,
