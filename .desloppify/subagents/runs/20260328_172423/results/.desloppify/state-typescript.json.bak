        "related_files": [
          "src/lib/pipeline/feed-filter.ts"
        ],
        "evidence": [
          "Functions getAuthor(raw: any), hasAttestation(raw: any), getText(raw: any), getCategory(raw: any), normalizeFeedPosts(payload: any) all accept any. Public APIs filterPosts(rawPosts: any[]) and combinedTopicSearch broadPool?: any[] propagate any to callers."
