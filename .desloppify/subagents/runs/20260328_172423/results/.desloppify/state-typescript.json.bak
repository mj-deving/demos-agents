          "src/lib/tlsn-playwright-bridge.ts"
        ],
        "evidence": [
          "Casts like (demos as any).crypto.getIdentity, (demos as any).nodeCall, (demos as any).getAddress access SDK methods that exist at runtime but are not in the TypeScript type definitions for @kynesyslabs/demosdk"
