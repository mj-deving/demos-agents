    "review::.::holistic::logic_clarity::apicall_unreachable_fallback": {
      "id": "review::.::holistic::logic_clarity::apicall_unreachable_fallback",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "low",
      "summary": "apiCall has a return after the retry loop marked as unreachable but needed to satisfy TypeScript",
      "detail": {
        "holistic": true,
        "dimension": "logic_clarity",
        "related_files": [
          "src/lib/network/sdk.ts"
        ],
        "evidence": [
          "Lines 255-256: `// Should never reach here, but satisfy TypeScript` followed by `return { ok: false, status: 502, data: 'Max retries exceeded on 502' }` \u2014 the for loop with MAX_RETRIES=3 always returns from either the try or catch blocks, so this line is indeed unreachable dead code"
        ],
        "suggestion": "This is a known TypeScript limitation where the compiler cannot prove loop exhaustion. The current approach (commented unreachable return) is the standard pragmatic fix. No action needed \u2014 just noting it as dead code that is justified.",
        "reasoning": "",
        "summary_hash": "dfd2d336"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-28T17:34:30+00:00",
      "last_seen": "2026-03-28T17:34:30+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "typescript",
      "suppressed": false,
