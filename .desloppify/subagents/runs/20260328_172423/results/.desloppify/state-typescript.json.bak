    "review::.::holistic::cross_module_architecture::extensions_plugin_cycle": {
      "id": "review::.::holistic::cross_module_architecture::extensions_plugin_cycle",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Import cycle: extensions.ts imports RunToolFn type from calibrate-plugin.ts, violating core->plugin direction",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "src/lib/util/extensions.ts",
          "src/plugins/calibrate-plugin.ts"
        ],
        "evidence": [
          "Line 150 of extensions.ts: import type { RunToolFn } from '../../plugins/calibrate-plugin.js' \u2014 core utility reaching up into plugin layer",
          "Confirmed by desloppify show cycles: 2-file cycle extensions.ts <-> calibrate-plugin.ts"
        ],
        "suggestion": "Move the RunToolFn type definition to src/lib/util/extensions.ts itself (or a shared types file in lib/). It is a simple function signature (toolPath: string, args: string[], label: string) => Promise<any> that does not depend on any plugin internals. calibrate-plugin.ts should import it from the core layer instead.",
        "reasoning": "",
        "summary_hash": "0928c0aa"
