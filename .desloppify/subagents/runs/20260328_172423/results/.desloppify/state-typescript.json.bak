    "review::.::holistic::error_consistency::bridge_apicall_untyped_errors": {
      "id": "review::.::holistic::error_consistency::bridge_apicall_untyped_errors",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "sdk-bridge.ts apiCall catch returns string error data \u2014 callers cannot distinguish error types",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "src/toolkit/sdk-bridge.ts"
        ],
        "evidence": [
          "Line 563-567: catch block returns { ok: false, status: 0, data: `[${errorName}] ${message}` } \u2014 error type is lost in string interpolation",
          "Callers like scan.ts, react.ts only check .ok \u2014 they cannot tell if the failure was network timeout, DNS failure, auth expiry, or rate limiting"
        ],
        "suggestion": "Return a structured error in the data field: { ok: false, status: 0, data: null, error: { type: err.constructor.name, message: err.message } }. Or add a dedicated 'errorType' field to ApiCallResult. This lets callers switch on error category without parsing strings.",
        "reasoning": "",
        "summary_hash": "ddeb381a"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-28T17:34:30+00:00",
      "last_seen": "2026-03-28T17:34:30+00:00",
      "resolved_at": null,
