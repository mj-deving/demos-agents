    "review::.::holistic::type_safety::ts_bridge_function_params": {
      "id": "review::.::holistic::type_safety::ts_bridge_function_params",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "txModule parameter typed with bare Function \u2014 call signatures are unchecked at every use site",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "src/toolkit/sdk-bridge.ts"
        ],
        "evidence": [
          "sdk-bridge.ts line 105: txModule?: { store: Function; confirm: Function; broadcast: Function }",
          "Actual call sites: tx.store(encoded, demos) line 244, tx.confirm(storeTx, demos) line 245, tx.broadcast(validity, demos) line 246",
          "Function type provides no parameter or return type constraints \u2014 passing wrong argument types compiles silently"
        ],
        "suggestion": "Replace bare Function with explicit call signatures: `{ store: (data: Uint8Array, sdk: unknown) => Promise<unknown>; confirm: (tx: unknown, sdk: unknown) => Promise<unknown>; broadcast: (validity: unknown, sdk: unknown) => Promise<unknown> }`. Using unknown for SDK-typed parameters is still safer than Function \u2014 it forces an explicit cast at use sites rather than silently accepting any argument.",
        "reasoning": "",
        "summary_hash": "4aaa572e"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-27T17:14:16+00:00",
      "last_seen": "2026-03-27T17:14:16+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "typescript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::type_safety::ts_bridge_any_cache_vars": {
      "id": "review::.::holistic::type_safety::ts_bridge_any_cache_vars",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "cachedTxModule and cachedD402Client typed as any \u2014 type information lost on cache-hit path",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "src/toolkit/sdk-bridge.ts"
        ],
        "evidence": [
          "sdk-bridge.ts line 108: let cachedTxModule: any = txModule ?? null",
          "sdk-bridge.ts line 109: let cachedD402Client: any = null",
          "After dynamic import: cachedTxModule = DemosTransactions (a static class object), cachedD402Client = new D402Client(demos) \u2014 both have known shapes post-import"
        ],
        "suggestion": "Use unknown instead of any for cache variables. `let cachedTxModule: unknown = txModule ?? null`. At the single use site `const tx = txModule ?? await getTxModule()`, the existing narrowing (checking that tx exists before calling tx.store) is already present \u2014 switching to unknown forces the existing code path through explicit narrowing rather than implicitly allowing all property access.",
        "reasoning": "",
        "summary_hash": "dd63458a"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-27T17:14:16+00:00",
      "last_seen": "2026-03-27T17:14:16+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "typescript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::type_safety::ts_duplicate_source_status": {
      "id": "review::.::holistic::type_safety::ts_duplicate_source_status",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "discover-sources.ts defines a local SourceStatus type that exactly duplicates the exported type in types.ts",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "src/toolkit/tools/discover-sources.ts",
          "src/toolkit/types.ts"
        ],
        "evidence": [
          "types.ts line 237: export type SourceStatus = 'active' | 'degraded' | 'quarantined' | 'stale' | 'deprecated' | 'archived'",
          "discover-sources.ts line 100: type SourceStatus = 'active' | 'degraded' | 'quarantined' | 'stale' | 'deprecated' | 'archived' (local, unexported)",
          "discover-sources.ts imports Source from types.ts (line 12) but not SourceStatus \u2014 the duplicate was introduced to avoid widening the import",
          "normalizeStatus() uses the local type for its return annotation; if types.ts adds a new status value, normalizeStatus will silently return 'active' for unrecognized values instead of passing them through"
        ],
        "suggestion": "Remove the local SourceStatus type definition on line 100 of discover-sources.ts and add SourceStatus to the import on line 12: `import type { DiscoverSourcesOptions, DiscoverSourcesResult, Source, SourceStatus, ToolResult } from '../types.js'`.",
        "reasoning": "",
        "summary_hash": "41b0ddb6"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-27T17:14:16+00:00",
      "last_seen": "2026-03-27T17:14:16+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
