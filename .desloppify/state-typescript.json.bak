    "review::.::holistic::type_safety::ts_connect_sdk_demos_any": {
      "id": "review::.::holistic::type_safety::ts_connect_sdk_demos_any",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "connectSdk() return type has demos: any \u2014 Demos instance loses type information at connection site",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "src/toolkit/tools/connect.ts",
          "src/toolkit/sdk-bridge.ts"
        ],
        "evidence": [
          "connect.ts line 187: ): Promise<{ demos: any; address: string; authToken: string }>",
          "sdk-bridge.ts line 11: import type { Demos } from '@kynesyslabs/demosdk/websdk' \u2014 the Demos type IS importable",
          "createSdkBridge() in sdk-bridge.ts accepts `demos: Demos` as its first parameter (line 100), so the type exists and is usable",
          "The any typing on demos means all downstream uses of the Demos instance lose IDE support and compiler checking"
        ],
        "suggestion": "In connect.ts, add `import type { Demos } from '@kynesyslabs/demosdk/websdk'` and change the connectSdk() return type to `Promise<{ demos: Demos; address: string; authToken: string }>`. The lazy import pattern does not prevent using the type at the signature level \u2014 type imports are compile-time only.",
        "reasoning": "",
        "summary_hash": "c1f115f5"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-27T17:14:16+00:00",
