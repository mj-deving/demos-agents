      "id": "review::.::holistic::design_coherence::sdk_bridge_silent_catch",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "apiCall() catch block silently converts network exceptions to ok:false response \u2014 callers cannot distinguish DNS failure from HTTP 500",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "src/toolkit/sdk-bridge.ts"
        ],
        "evidence": [
          "Lines 199-201: catch(err) { return { ok: false, status: 0, data: (err as Error).message }; }",
          "status: 0 is the only signal that this was a network error vs an HTTP error; callers checking result.ok will treat both identically",
          "The existing DemosError system has a NETWORK_ERROR code with retryable:true that is the correct carrier for this case"
        ],
        "suggestion": "Re-throw or surface as a DemosError(NETWORK_ERROR) so that callers can distinguish retryable network failures from non-retryable HTTP errors. If apiCall must never throw, add a third field (e.g., networkError: true) to ApiCallResult.",
        "reasoning": "",
